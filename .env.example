# meta-agent configuration
# Copy to .env and fill in what you need.


# --- API keys ------------------------------------------------------------

# AWS Bedrock — REQUIRED for every Claude call in this project (judges,
# proposers, tau-bench user simulators). Direct api.anthropic.com access
# is not used. Provide a bearer token OR rely on the standard AWS credential
# chain (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY). See meta_agent/llm_client.py.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# OpenAI — required for Codex-based runs and for tau-bench user simulators.
OPENAI_API_KEY=

# Modal — optional, for running meta-agent on Modal cloud containers.
# See meta_agent/cloud/MODAL.md for setup: `modal token new` and `python -m
# meta_agent.cloud.modal_runner upload-codex-auth` are the one-time commands.
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=


# --- meta-agent itself ---------------------------------------------------

# Root directory meta-agent writes to for experience/ and staging/. Defaults
# to the current working directory when unset.
# META_AGENT_WORKSPACE_ROOT=

# Logger verbosity. DEBUG | INFO | WARNING | ERROR. Default: INFO.
# META_AGENT_LOG_LEVEL=INFO


# --- Codex runtime -------------------------------------------------------

# Force meta-agent to emulate Codex hooks from .codex/hooks.json even if
# the installed `codex` CLI has native hooks support. Leave unset unless
# debugging.
# META_AGENT_FORCE_CODEX_HOOK_EMULATION=0

# Assume the installed `codex` CLI has native hooks support without
# probing (skips `codex features list`). Useful in constrained test envs.
# META_AGENT_ASSUME_CODEX_NATIVE_HOOKS=0

# Sandbox mode passed to `codex exec` when acting as the proposer. Leave
# unset to use the codex default. Common values: "workspace-write",
# "read-only", "danger-full-access".
# CODEX_SANDBOX_MODE=

# Bypass Codex approvals + sandbox. Only set when you trust the model and
# the workspace is disposable. Accepts "1" / "true" / "yes".
# CODEX_DANGEROUS_BYPASS=0


# --- Claude runtime ------------------------------------------------------

# Permission mode for Claude Agent SDK and Claude Code. Default:
# "bypassPermissions". Other common values: "acceptEdits", "plan".
# On Modal (root container) `bypassPermissions` is blocked; the Modal
# runner image hardcodes "acceptEdits" automatically.
# CLAUDE_PERMISSION_MODE=bypassPermissions

# Claude Agent SDK initialize timeout (milliseconds). Bump from the SDK
# default of 60000 when running at high concurrency — 100 parallel
# subprocesses spawning simultaneously can exceed 60s handshake time.
# Default here gives 5 min of slack.
CLAUDE_CODE_STREAM_CLOSE_TIMEOUT=300000

# (Note: CLAUDE_CODE_USE_BEDROCK is no longer user-configurable — this
# project unconditionally routes every Claude call through AWS Bedrock.
# The `claude` CLI and Claude Agent SDK receive it via subprocess env.)

